# weather-tracker environment configuration
# Copy this file to .env and fill in the required values before running:
#   cp .env.example .env
# docker-compose reads from .env automatically.

# ── Required (no defaults) ────────────────────────────────────────────────────

# Latitude of the location to track. Range: -90 to 90.
TRACKED_LATITUDE=39.7456

# Longitude of the location to track. Range: -180 to 180.
TRACKED_LONGITUDE=-97.0892

# User-Agent header sent to weather.gov. Required by the API; without it you
# get 403. Do not include a real email address.
WEATHER_GOV_USER_AGENT=weather-tracker/0.1

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# How often to poll weather.gov, in minutes.
POLL_INTERVAL_MINUTES=60

# How many hourly forecast entries to store per poll (first N from the API).
FORECAST_HOURS_WINDOW=72

# SQLite database URL.
# - For local commands (uv run alembic upgrade head, pytest, etc.) use a
#   relative or absolute path that exists on your machine.
# - docker-compose.yml overrides this to sqlite:////data/weather.db so the
#   container always writes to the mounted volume regardless of .env.
DATABASE_URL=sqlite:///./weather.db

# Logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# HTTP timeout for weather.gov requests, in seconds.
WEATHER_GOV_TIMEOUT_SECONDS=30

# Maximum number of retries for weather.gov requests on 5xx / network errors.
WEATHER_GOV_MAX_RETRIES=3

# Port the uvicorn server listens on inside the container.
API_PORT=8000
